<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.dev/DTDs/PropertyList-1.0.dtd">
<!--
  RadioPad macOS hardened-runtime entitlements.

  Notes:
    - allow-jit is required by V8 / WebKit JIT used inside the Tauri WebView.
    - disable-library-validation is intentionally NOT enabled (commented out) so
      Gatekeeper still verifies team-id + signing of every loaded library.
    - allow-unsigned-executable-memory is explicitly false.
    - We only request the minimal network.client + user-selected files scopes;
      we do not enable App Sandbox broad filesystem entitlements.
-->
<plist version="1.0">
  <dict>
    <key>com.apple.security.cs.allow-jit</key>
    <true/>

    <!--
      <key>com.apple.security.cs.disable-library-validation</key>
      <false/>
    -->

    <key>com.apple.security.cs.allow-unsigned-executable-memory</key>
    <false/>

    <key>com.apple.security.network.client</key>
    <true/>

    <key>com.apple.security.files.user-selected.read-write</key>
    <true/>
  </dict>
</plist>
