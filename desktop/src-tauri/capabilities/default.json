{
  "$schema": "https://schema.tauri.app/config/2.0/capability",
  "identifier": "default",
  "description": "Default capabilities for the RadioPad desktop main window. Minimised per DESK-D4 permissions audit — only IPC commands required by the frontend are granted.",
  "windows": ["main"],
  "permissions": [
    "core:default",
    {
      "identifier": "shell:allow-spawn",
      "allow": [{ "name": "radiopad-api", "sidecar": true }]
    },
    "dialog:allow-open",
    "dialog:allow-save",
    "clipboard-manager:allow-write-text",
    "clipboard-manager:allow-read-text",
    "store:allow-get",
    "store:allow-set",
    "store:allow-delete",
    "store:allow-keys",
    "store:allow-save",
    "notification:default",
    "updater:default",
    "process:allow-restart"
  ]
}
