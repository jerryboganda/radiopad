{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://radiopad.local/schemas/pacs-plugin.manifest.json",
  "title": "RadioPad PACS plugin manifest",
  "description": "Signed manifest describing a vendor PACS adapter (Sectra, AGFA, Visage, Merge, Hyland). Verified by SHA-256 + Ed25519 against RADIOPAD_PLUGIN_PUBKEY.",
  "type": "object",
  "required": ["id", "name", "vendor", "version", "sha256", "capabilities"],
  "additionalProperties": false,
  "properties": {
    "id": {
      "type": "string",
      "pattern": "^[a-z][a-z0-9-]{1,63}$",
      "description": "Kebab-case plugin identifier."
    },
    "name": { "type": "string", "minLength": 1, "maxLength": 128 },
    "vendor": {
      "type": "string",
      "enum": ["Sectra", "AGFA", "Visage", "Merge", "Hyland", "Other"]
    },
    "version": {
      "type": "string",
      "pattern": "^\\d+\\.\\d+\\.\\d+(?:-[0-9A-Za-z.-]+)?$"
    },
    "description": { "type": "string", "maxLength": 1024 },
    "homepage": { "type": "string", "format": "uri" },
    "sha256": {
      "type": "string",
      "pattern": "^[0-9a-f]{64}$",
      "description": "Lowercase hex SHA-256 of the manifest body with this field zeroed (canonical JSON, sorted keys, no whitespace)."
    },
    "capabilities": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": {
        "enum": [
          "window-detect",
          "accession-grab",
          "paste-back",
          "hanging-protocol",
          "study-launch"
        ]
      }
    },
    "executable": {
      "type": "string",
      "description": "Optional path (relative to the plugin folder) to a native helper binary. Must be hashed + signed."
    },
    "executable_sha256": { "type": "string", "pattern": "^[0-9a-f]{64}$" },
    "executable_sig_b64": { "type": "string" },
    "enabled": { "type": "boolean", "default": false },
    "minDesktopVersion": { "type": "string", "pattern": "^\\d+\\.\\d+\\.\\d+$" },
    "compliance": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "phi": {
          "type": "string",
          "enum": ["never", "metadata-only", "full"],
          "description": "What categories of data the plugin may surface."
        },
        "auditTopics": {
          "type": "array",
          "items": { "type": "string" }
        }
      }
    }
  }
}
