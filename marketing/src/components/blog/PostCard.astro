---
import { Image } from "astro:assets";
import type { CollectionEntry } from "astro:content";

interface Props {
  post: CollectionEntry<"blog">;
}
const { post } = Astro.props;
const { data, id } = post;
const dateStr = data.date.toLocaleDateString("en-US", { year: "numeric", month: "long", day: "numeric" });
---
<article class="card">
  <a href={`/blog/${id}/`} class="cover" aria-label={data.title}>
    <Image src={data.cover} alt={data.coverAlt} widths={[320, 640]} sizes="(max-width: 900px) 100vw, 33vw" loading="lazy" />
  </a>
  <div class="body">
    <div class="post-meta">{data.tags[0] && <span class="tag">{data.tags[0]}</span>}</div>
    <h3><a href={`/blog/${id}/`}>{data.title}</a></h3>
    <p class="excerpt">{data.description}</p>
    <div class="post-meta foot"><span>{dateStr}</span><span>&middot;</span><span>{data.readingTime}</span></div>
  </div>
</article>
