---
import { getCollection } from "astro:content";
import { Image } from "astro:assets";
import { site } from "../../lib/site";
import BaseLayout from "../../layouts/BaseLayout.astro";
import PostCard from "../../components/blog/PostCard.astro";
import Motion from "../../components/Motion.svelte";
import Newsletter from "../../components/Newsletter.svelte";

const posts = (await getCollection("blog", ({ data }) => !data.draft)).sort(
  (a, b) => b.data.date.valueOf() - a.data.date.valueOf()
);

const featured = posts.find((p) => p.data.featured) ?? posts[0];
const rest = posts.filter((p) => p.id !== featured.id);
const tags = [...new Set(posts.flatMap((p) => p.data.tags))].sort();

const fDate = featured.data.date.toLocaleDateString("en-US", { year: "numeric", month: "long", day: "numeric" });
---

<BaseLayout title="Blog" description="Notes on AI-assisted radiology reporting, validation, rulebooks, interoperability, and keeping the radiologist in control." navCurrent="Blog">
  <main id="main">
    <section class="blog-head">
      <div class="wrap">
        <p class="eyebrow">The RadioPad blog</p>
        <h1>Notes on drafting, validating, and signing.</h1>
        <p>How we build assisted reporting that keeps the radiologist in control, plus practical notes on rulebooks, validation, and interoperability.</p>
      </div>
    </section>

    <section class="featured">
      <div class="wrap">
        <a href={`/blog/${featured.id}/`} class="reveal">
          <div class="cover">
            <Image src={featured.data.cover} alt={featured.data.coverAlt} widths={[540, 900]} sizes="(max-width: 820px) 100vw, 50vw" loading="eager" />
          </div>
          <div class="body">
            <div class="post-meta"><span class="tag">{featured.data.tags[0]}</span><span>Featured</span></div>
            <h2>{featured.data.title}</h2>
            <p class="standfirst">{featured.data.description}</p>
            <div class="post-meta" style="margin-top:1.2rem"><span>{featured.data.author.name}</span><span>&middot;</span><span>{fDate}</span><span>&middot;</span><span>{featured.data.readingTime}</span></div>
          </div>
        </a>
      </div>
    </section>

    <nav class="filter" aria-label="Filter posts by tag">
      <div class="wrap">
        <a class="pill" href="/blog" aria-current="page">All</a>
        {tags.map((t) => <a class="pill" href={`/blog/tag/${t.toLowerCase()}/`}>{t}</a>)}
      </div>
    </nav>

    <section class="grid-sec">
      <div class="wrap">
        <div class="post-grid">
          {rest.map((post) => <PostCard post={post} />)}
        </div>
      </div>
    </section>

    <section class="subscribe">
      <div class="wrap">
        <div class="sub-band reveal">
          <div>
            <h2>New writing, now and then.</h2>
            <p>Occasional notes on assisted reporting and how we keep radiologists in control. No noise.</p>
          </div>
          <Newsletter client:visible />
        </div>
      </div>
    </section>
  </main>
  <Motion client:visible mode="index" />
</BaseLayout>
