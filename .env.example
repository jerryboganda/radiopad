# RadioPad — example environment variables
# Copy to .env.prod and fill in values; never commit real secrets.

# ----------------------------------------------------------------- backend
# Bind address. Default 127.0.0.1:7457. Set to 0.0.0.0:7457 only if you have
# put the API behind a TLS reverse proxy and accepted the security review.
RADIOPAD_BIND=127.0.0.1:7457

# ASP.NET Core environment: Development | Staging | Production | Testing
ASPNETCORE_ENVIRONMENT=Development

# Connection string. SQLite for dev, PostgreSQL for prod (sniffed automatically).
# Preferred ASP.NET Core key; RADIOPAD_DB remains accepted for compatibility.
ConnectionStrings__RadioPad=Data Source=radiopad.dev.db
# ConnectionStrings__RadioPad=Host=postgres;Database=radiopad;Username=radiopad;Password=<REDACTED_SECRET>

# Required in production for RadioPad-issued bearer tokens.
RADIOPAD_AUTH_SECRET=<REDACTED_SECRET>
RADIOPAD_PUBLIC_WEB_URL=https://radiopad.example.com
RADIOPAD_DEV_HEADERS=0
RADIOPAD_ENABLE_SWAGGER=0

# Required in production for at-rest column encryption. RADIOPAD_COLUMN_KEK is
# a base64 32-byte wrapping key; RADIOPAD_COLUMN_KEY_WRAPPED is a base64
# wrapped 32-byte data key produced by the configured KMS provider.
# openssl rand -base64 32
RADIOPAD_COLUMN_KEY_REF=env:RADIOPAD_COLUMN_KEK
RADIOPAD_COLUMN_KEK=<REDACTED_SECRET>
RADIOPAD_COLUMN_KEY_WRAPPED=<REDACTED_SECRET>

# Trust X-Forwarded-For only when your reverse proxy peer is inside these CIDRs.
RADIOPAD_TRUST_FORWARDED_FOR=0
# RADIOPAD_TRUSTED_PROXY_CIDRS=172.16.0.0/12,10.0.0.0/8

# ----------------------------------------------------------------- ai providers
# Each provider entry stores ApiKeySecretRef = "env:<NAME>". Below are the
# environment variable names referenced by the seed providers.
ANTHROPIC_API_KEY=<REDACTED_SECRET>
OLLAMA_BASE_URL=http://127.0.0.1:11434
# OPENAI_API_KEY=<REDACTED_SECRET>   # optional, only if you add an OpenAI provider
# OpenAI-compatible endpoints may reference any env-var name from ApiKeySecretRef.
# Example provider row: ApiKeySecretRef = "env:OPENAI_COMPATIBLE_API_KEY".
# OPENAI_COMPATIBLE_API_KEY=<REDACTED_SECRET>

# CLI provider controls. CLI providers default to Sandbox; do not route PHI
# unless Security/Regulatory has explicitly approved the provider row.
# RADIOPAD_COPILOT_BIN=copilot
# Desktop-only GitHub CLI binary used for status/login/logout helper commands.
# RADIOPAD_GH_BIN=gh
# RADIOPAD_GEMINI_BIN=gemini
# RADIOPAD_CODEX_BIN=codex
# Server-side Copilot CLI execution in Production must also opt in explicitly.
# RADIOPAD_COPILOT_SERVER_CLI_ENABLED=0
# RADIOPAD_CODEX_CLI_ENABLED=0
# RADIOPAD_CLI_PROVIDER_TIMEOUT_MS=60000
# RADIOPAD_CLI_PROVIDER_ALLOWED_PATHS=
# RADIOPAD_CLI_PROVIDER_ENV_ALLOWLIST=
# RADIOPAD_OPENAI_COMPATIBLE_ALLOW_PHI=0

# Passwordless magic-link email. Required for production magic-link login.
# RADIOPAD_SMTP_HOST=smtp.example.com
# RADIOPAD_SMTP_PORT=587
# RADIOPAD_SMTP_USER=<REDACTED_SECRET>
# RADIOPAD_SMTP_PASS=<REDACTED_SECRET>
# RADIOPAD_SMTP_FROM="RadioPad <no-reply@example.com>"
# RADIOPAD_SMTP_REPLY_TO=support@example.com
# RADIOPAD_SMTP_TLS_HOST=smtp.example.com

# GitHub Copilot SDK provider is fail-closed unless a reviewed official
# backend-safe transport is installed and this flag is intentionally set.
# RADIOPAD_GITHUB_COPILOT_SDK_ENABLED=false

# ----------------------------------------------------------------- frontend
# Public base URL for the API. Leave empty in dev to use the Next.js rewrite.
NEXT_PUBLIC_API_BASE=

# ----------------------------------------------------------------- desktop / mobile
# Tauri bundles use frontend/out — no env vars required.

# ----------------------------------------------------------------- ops
# Optional Sentry/OTel endpoints (planned, not yet wired).
# OTEL_EXPORTER_OTLP_ENDPOINT=http://127.0.0.1:4317
# SENTRY_DSN=<REDACTED_SECRET>

# ----------------------------------------------------------------- production compose (deploy/docker-compose.prod.yml)
# Set these when deploying with docker compose --env-file .env.prod
POSTGRES_USER=radiopad
POSTGRES_PASSWORD=<REDACTED_SECRET>
POSTGRES_DB=radiopad
IMAGE_TAG=latest
RADIOPAD_DOMAIN=radiopad.example.com
RADIOPAD_DEFAULT_TENANT=default
RADIOPAD_RUN_MIGRATIONS=true
# Orthanc (only when running with --profile pacs)
RADIOPAD_ORTHANC_USERNAME=radiopad
RADIOPAD_ORTHANC_PASSWORD=<REDACTED_SECRET>
