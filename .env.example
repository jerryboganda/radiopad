# RadioPad — example environment variables
# Copy to .env.prod and fill in values; never commit real secrets.

# ----------------------------------------------------------------- backend
# Bind address. Default 127.0.0.1:7457. Set to 0.0.0.0:7457 only if you have
# put the API behind a TLS reverse proxy and accepted the security review.
RADIOPAD_BIND=127.0.0.1:7457

# ASP.NET Core environment: Development | Staging | Production | Testing
ASPNETCORE_ENVIRONMENT=Development

# Connection string. SQLite for dev, PostgreSQL for prod (sniffed automatically).
# Preferred ASP.NET Core key; RADIOPAD_DB remains accepted for compatibility.
ConnectionStrings__RadioPad=Data Source=radiopad.dev.db
# ConnectionStrings__RadioPad=Host=postgres;Database=radiopad;Username=radiopad;Password=<REDACTED_SECRET>

# Required in production for RadioPad-issued bearer tokens.
RADIOPAD_AUTH_SECRET=<REDACTED_SECRET>
RADIOPAD_PUBLIC_WEB_URL=https://radiopad.example.com
RADIOPAD_DEV_HEADERS=0
# Require a real session: reject tokenless requests (401) instead of resolving a
# default identity, so the app opens the login screen first. The desktop sidecar
# sets this automatically; enable it for any shared deployment.
RADIOPAD_REQUIRE_AUTH=1
RADIOPAD_ENABLE_SWAGGER=0

# WebAuthn / Windows Hello (fingerprint + face). RP id must match the origin the
# app is served from: localhost for web dev, tauri.localhost for the desktop
# WebView2 shell. Origins is an optional explicit allow-list (comma-separated);
# leave blank to derive from the RP id. Require UV to force the biometric/PIN gesture.
RADIOPAD_WEBAUTHN_RP_ID=localhost
RADIOPAD_WEBAUTHN_RP_NAME=RadioPad
RADIOPAD_WEBAUTHN_ORIGINS=
RADIOPAD_WEBAUTHN_REQUIRE_UV=1

# Required in production for at-rest column encryption. RADIOPAD_COLUMN_KEK is
# a base64 32-byte wrapping key; RADIOPAD_COLUMN_KEY_WRAPPED is a base64
# wrapped 32-byte data key produced by the configured KMS provider.
# openssl rand -base64 32
RADIOPAD_COLUMN_KEY_REF=env:RADIOPAD_COLUMN_KEK
RADIOPAD_COLUMN_KEK=<REDACTED_SECRET>
RADIOPAD_COLUMN_KEY_WRAPPED=<REDACTED_SECRET>

# Trust X-Forwarded-For only when your reverse proxy peer is inside these CIDRs.
RADIOPAD_TRUST_FORWARDED_FOR=0
# RADIOPAD_TRUSTED_PROXY_CIDRS=172.16.0.0/12,10.0.0.0/8

# ----------------------------------------------------------------- ai providers
# Each provider entry stores ApiKeySecretRef = "env:<NAME>". Below are the
# environment variable names referenced by the seed providers.
ANTHROPIC_API_KEY=<REDACTED_SECRET>
OLLAMA_BASE_URL=http://127.0.0.1:11434
# OPENAI_API_KEY=<REDACTED_SECRET>   # optional, only if you add an OpenAI provider
# OpenAI-compatible endpoints may reference any env-var name from ApiKeySecretRef.
# Example provider row: ApiKeySecretRef = "env:OPENAI_COMPATIBLE_API_KEY".
# OPENAI_COMPATIBLE_API_KEY=<REDACTED_SECRET>

# CLI provider controls. CLI providers default to Sandbox; do not route PHI
# unless Security/Regulatory has explicitly approved the provider row.
# RADIOPAD_GEMINI_BIN=gemini
# RADIOPAD_CODEX_BIN=codex
# RADIOPAD_CODEX_CLI_ENABLED=0
# RADIOPAD_CLI_PROVIDER_TIMEOUT_MS=60000
# Production is default-deny: the allowlist must list the EXACT resolved binary
# path (matched against RADIOPAD_GEMINI_BIN). In the VPS api image the gemini
# binary is at /usr/local/bin/gemini, so both are defaulted there in
# deploy/vps/docker-compose.yml. Set explicitly to override.
# RADIOPAD_CLI_PROVIDER_ALLOWED_PATHS=/usr/local/bin/gemini
# RADIOPAD_CLI_PROVIDER_ENV_ALLOWLIST=
# RADIOPAD_OPENAI_COMPATIBLE_ALLOW_PHI=0

# UBAG browser-automation gateway (backend only; never expose to the frontend).
# Production uses the internal docker-network address on the shared `platform`
# network — never the public Basic-auth'd https://ubag.polytronx.com.
# RADIOPAD_UBAG_BASE_URL=http://ubag-vps-gateway-1:8080
# Auth: secret-ref pattern; the token is UBAG's UBAG_APP_SECRET, sent as
# Authorization: Bearer. If unset, requests go out with NO auth header —
# production must always set it.
# RADIOPAD_UBAG_AUTH_SECRET_REF=env:RADIOPAD_UBAG_TOKEN
# RADIOPAD_UBAG_TOKEN=<REDACTED_SECRET>
# Default-deny target allowlist; unset = chatgpt_web,gemini_web,deepseek_web,mock.
# RADIOPAD_UBAG_ALLOWED_TARGETS=gemini_web,deepseek_web,chatgpt_web,mock
# Ordered web-chain workflow targets; code default gemini_web,deepseek_web.
# RADIOPAD_UBAG_ORDERED_TARGETS=gemini_web,deepseek_web
# Optional operator inbox for login-lost / gateway-unreachable alert emails
# (throttled 1/day/target); unset = Hub banners only.
# RADIOPAD_OPERATOR_ALERT_EMAIL=ops@example.com

# Transactional email via HTTPS REST API (Gmail API recommended).
# Bypasses DigitalOcean SMTP block for guaranteed deliverability.
# RADIOPAD_EMAIL_PROVIDER=gmail             # gmail | resend | sendgrid | mailgun
# RADIOPAD_EMAIL_FROM="RadioPad <noreply@radiopad.polytronx.com>"
# RADIOPAD_EMAIL_REPLY_TO=support@radiopad.polytronx.com

# Gmail API OAuth2 (recommended — uses your existing Gmail/Google Workspace)
# 1. Create project at https://console.cloud.google.com
# 2. Enable Gmail API
# 3. Create OAuth2 Desktop credentials → get client_id + client_secret
# 4. Run the consent flow once to get refresh_token (see docs/04-security/gmail-oauth-setup.md)
# RADIOPAD_GMAIL_CLIENT_ID=<your-client-id>.apps.googleusercontent.com
# RADIOPAD_GMAIL_CLIENT_SECRET=<REDACTED_SECRET>
# RADIOPAD_GMAIL_REFRESH_TOKEN=<REDACTED_SECRET>

# Alternative providers (if not using Gmail):
# RADIOPAD_EMAIL_API_KEY=<REDACTED_SECRET>
# RADIOPAD_MAILGUN_DOMAIN=mg.radiopad.polytronx.com  # only needed for Mailgun

# ----------------------------------------------------------------- frontend
# Public base URL for the API. Leave empty in dev to use the Next.js rewrite.
NEXT_PUBLIC_API_BASE=

# ----------------------------------------------------------------- desktop / mobile
# Tauri bundles use frontend/out — no env vars required.

# ----------------------------------------------------------------- ops
# Optional Sentry/OTel endpoints (planned, not yet wired).
# OTEL_EXPORTER_OTLP_ENDPOINT=http://127.0.0.1:4317
# SENTRY_DSN=<REDACTED_SECRET>

# ----------------------------------------------------------------- production compose (deploy/docker-compose.prod.yml and deploy/vps/docker-compose.yml)
# Set these when deploying with docker compose --env-file .env.prod
POSTGRES_USER=radiopad
POSTGRES_PASSWORD=<REDACTED_SECRET>
POSTGRES_DB=radiopad
RADIOPAD_WEB_PORT=8093
IMAGE_TAG=latest
RADIOPAD_DOMAIN=radiopad.example.com
RADIOPAD_DEFAULT_TENANT=default
RADIOPAD_RUN_MIGRATIONS=true
# Orthanc (only when running with --profile pacs)
RADIOPAD_ORTHANC_USERNAME=radiopad
RADIOPAD_ORTHANC_PASSWORD=<REDACTED_SECRET>
