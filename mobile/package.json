{
  "name": "radiopad-mobile",
  "version": "0.1.0",
  "private": true,
  "description": "RadioPad mobile shell (Capacitor 6)",
  "scripts": {
    "build:web": "pnpm --filter @radiopad/frontend build",
    "sync": "pnpm build:web && cap sync",
    "android": "pnpm sync && cap open android",
    "ios": "pnpm sync && cap open ios"
  },
  "dependencies": {
    "@capacitor-community/secure-storage": "^4.0.0",
    "@capacitor-community/speech-recognition": "^6.0.0",
    "@capacitor/android": "^6.1.2",
    "@capacitor/core": "^6.1.2",
    "@capacitor/ios": "^6.1.2",
    "@capacitor/network": "^6.0.3",
    "@capacitor/preferences": "^6.0.3",
    "@capacitor/splash-screen": "^6.0.2"
  },
  "devDependencies": {
    "@aparajita/capacitor-biometric-auth": "^7.0.0",
    "@capacitor/cli": "^6.1.2",
    "@capacitor/push-notifications": "^6.0.4"
  }
}
