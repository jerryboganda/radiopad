.codex/

# Claude Code: track the SHARED team config so hooks/agents/commands/skills reach the
# whole team (.claude/settings.json, .claude/agents/, .claude/commands/, .claude/skills/,
# plus root-level hooks/ and .mcp.json). Keep only per-developer local overrides out of git.
.claude/settings.local.json
.claude/*.local.json

# Most .claude/skills/ entries are per-developer symlinks into a local .agents/ library
# (which is itself gitignored) and resolve only on the author's machine — never commit them.
# Track only the repo-specific skills that live here as real files.
.claude/skills/*
!.claude/skills/ef-migration-helper/
!.claude/skills/scaffold-radiopad-page/
!.claude/skills/verify-both-themes/

# Commander task scratchpad; keep local task notes out of git by default.
.task/

# Local CodeGraph index — large local DB, never commit.
.codegraph/

# Secrets & env files — NEVER commit (this is a PHI app). `.env.example` is the
# only env file that may be tracked.
.env
.env.*
!.env.example
.secrets.env
*.secret
*.key
*.pem
*.pfx
*.p12
*.sec
# Private signing material (also matched by *.sec above; kept explicit).
mcp-connectors/_signing/release.sec

# Generated gap-analysis / audit scratch artifacts.
.gap_*

# Test output logs
tsc_output.txt

# Dev databases
*.dev.db
*.dev.db-shm
*.dev.db-wal
