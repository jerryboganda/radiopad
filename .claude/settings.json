{
  "$comment": "Shared Claude Code settings for RadioPad (committed — see hooks/README.md). Per-developer overrides go in .claude/settings.local.json (gitignored). Run `claude` from the repo root so the relative hook paths resolve. All hooks are advisory: they ask/remind, never mutate files or block outright.",
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash|PowerShell",
        "hooks": [
          { "type": "command", "command": "node hooks/pretooluse.mjs", "timeout": 10 }
        ]
      },
      {
        "matcher": "Edit|Write|MultiEdit",
        "hooks": [
          { "type": "command", "command": "node hooks/designlock.mjs", "timeout": 10 }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Edit|Write|MultiEdit",
        "hooks": [
          { "type": "command", "command": "node hooks/dotnet-format.mjs", "timeout": 60 }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          { "type": "command", "command": "node hooks/release-reminder.mjs", "timeout": 15 }
        ]
      }
    ],
    "SessionStart": [
      {
        "hooks": [
          { "type": "command", "command": "node hooks/session-start.mjs", "timeout": 10 }
        ]
      }
    ]
  }
}
